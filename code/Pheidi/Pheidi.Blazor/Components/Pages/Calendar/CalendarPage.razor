@page "/calendar"
@rendermode InteractiveServer
@implements IDisposable
@using Pheidi.Blazor.Components.Shared
@using Pheidi.Blazor.Components.Shared.Injury
@using Pheidi.Blazor.Components.Shared.Logging
@using Pheidi.Blazor.Services
@using Pheidi.Common.Engines
@using Pheidi.Common.Services
@inject PlanStateService PlanState
@inject AuthStateService AuthState
@inject WorkoutRepository WorkoutRepo
@inject UserService UserService
@inject NavigationManager Navigation
@inject WorkoutLoggingService LoggingService
@inject ScheduleFlexibilityEngine FlexEngine

<PageTitle>Pheidi - Training Calendar</PageTitle>

@if (!AuthState.IsAuthenticated)
{
    <div class="text-center mt-5">
        <h4>Sign in to view your calendar</h4>
        <p class="text-muted">You need to be signed in to access your training plan.</p>
        <a href="/signin" class="btn btn-primary"><i class="fas fa-user me-2"></i>Sign In</a>
    </div>
}
else if (PlanState.HasPausedPlan)
{
    <div class="text-center mt-5">
        <div class="alert alert-warning d-inline-block">
            <i class="fas fa-pause-circle fa-3x mb-3 d-block"></i>
            <h4>Plan Paused</h4>
            <p>Your training plan is paused. Resume when you're ready — no pressure.</p>
            <button class="btn btn-primary me-2" @onclick="HandleResume">
                <i class="fas fa-play me-1"></i>Resume Plan
            </button>
            <button class="btn btn-outline-danger" @onclick="() => showAbandonConfirm = true">
                <i class="fas fa-times me-1"></i>Abandon Plan
            </button>
        </div>
        @if (showAbandonConfirm)
        {
            <div class="alert alert-secondary mt-3 d-inline-block">
                <p class="mb-2">Are you sure? This will archive your plan.</p>
                <button class="btn btn-sm btn-danger me-2" @onclick="HandleAbandon">Yes, Archive</button>
                <button class="btn btn-sm btn-outline-secondary" @onclick="() => showAbandonConfirm = false">Cancel</button>
            </div>
        }
    </div>
}
else if (!PlanState.HasActivePlan)
{
    <div class="text-center mt-5">
        <h4>No active training plan</h4>
        <p class="text-muted">Set up your training plan to see your calendar.</p>
        <a href="/setup" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Create a Plan</a>
    </div>
}
else
{
    @* --- Active injury banner --- *@
    @if (activeInjury != null)
    {
        <div class="alert alert-warning mt-3">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <i class="fas fa-band-aid me-2"></i>
                    <strong>Active Injury — @FormatBodyPart(activeInjury.BodyPart)</strong> (Severity @activeInjury.Severity/10)
                    <div class="small mt-1">@InjuryEngine.GetGuidance(activeInjury.Severity)</div>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ShowUpdateInjury">
                        <i class="fas fa-edit me-1"></i>Update
                    </button>
                    <button class="btn btn-sm btn-outline-success" @onclick="ResolveInjury">
                        <i class="fas fa-check me-1"></i>Resolved
                    </button>
                </div>
            </div>
            @if (activeInjury.PainHistory.Count >= 2)
            {
                <div class="small mt-2">
                    <i class="fas fa-chart-line me-1"></i>Pain trend: <strong>@InjuryEngine.AnalyzeTrend(activeInjury.PainHistory)</strong>
                </div>
            }
            <div class="small mt-1">
                <i class="fas fa-dumbbell me-1"></i>Safe alternatives: @string.Join(", ", InjuryEngine.GetSafeCrossTraining(activeInjury.BodyPart))
            </div>
            @if (isRecurringInjury)
            {
                <div class="small mt-1 text-danger">
                    <i class="fas fa-exclamation-triangle me-1"></i>@InjuryEngine.GetRecurringMessage(activeInjury.BodyPart)
                </div>
            }
        </div>

        @if (showUpdateInjury)
        {
            <div class="card mb-3">
                <div class="card-body">
                    <h6>Update Pain Level: @updateSeverity / 10</h6>
                    <input type="range" class="form-range" min="1" max="10" @bind="updateSeverity" @bind:event="oninput" />
                    <div class="d-flex gap-2 mt-2">
                        <button class="btn btn-sm btn-primary" @onclick="SubmitInjuryUpdate">Save</button>
                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => showUpdateInjury = false">Cancel</button>
                    </div>
                </div>
            </div>
        }
    }

    @* --- Phase transition banner --- *@
    @if (GetPhaseTransitionMessage() is { } phaseMessage)
    {
        <div class="alert alert-info mt-3">
            <i class="fas fa-flag-checkered me-2"></i>@phaseMessage
        </div>
    }

    @* --- Milestone/streak banner --- *@
    @if (GetMilestoneMessage() is { } milestone)
    {
        <div class="alert alert-success mt-3">
            <i class="fas fa-trophy me-2"></i>@milestone
        </div>
    }
    @if (CalculateStreak() is var streak && streak >= 3)
    {
        <div class="small text-muted mt-2 mb-2">
            <i class="fas fa-fire text-warning me-1"></i>@MessagingService.GetStreakMessage(streak)
        </div>
    }

    @* --- End of plan summary --- *@
    @if (IsPlanComplete())
    {
        <EndOfPlanSummary Plan="PlanState.ActivePlan!" />
    }

    @* --- Today widget --- *@
    @if (GetTodayWorkout() is { } todayWorkout && !(currentView == CalendarView.Daily && selectedDate.Date == DateTime.Today))
    {
        <div class="card mt-3 border-primary">
            <div class="card-body d-flex justify-content-between align-items-center py-2">
                <div>
                    <span class="fw-bold text-primary"><i class="fas fa-sun me-1"></i>Today:</span>
                    @if (todayWorkout.Type == WorkoutType.Rest)
                    {
                        <span class="ms-2">Rest Day</span>
                    }
                    else
                    {
                        <span class="ms-2">@todayWorkout.Type — @todayWorkout.TargetDistanceMiles.ToString("F1") mi</span>
                        @if (todayWorkout.Status == WorkoutStatus.Completed)
                        {
                            <span class="badge bg-success ms-2"><i class="fas fa-check"></i></span>
                        }
                    }
                </div>
                <div class="d-flex gap-2">
                    @if (todayWorkout.Status == WorkoutStatus.Pending && todayWorkout.IsRunWorkout)
                    {
                        <button class="btn btn-sm btn-success" @onclick="() => QuickCompleteTodayWidget(todayWorkout)">
                            <i class="fas fa-check me-1"></i>Done
                        </button>
                    }
                    <button class="btn btn-sm btn-outline-primary" @onclick="GoToToday">
                        <i class="fas fa-arrow-right me-1"></i>View
                    </button>
                </div>
            </div>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mt-3 mb-3">
        <h4 class="mb-0">
            <i class="far fa-calendar-alt"></i>
            @PlanState.ActivePlan!.RaceGoal.Distance.DisplayName() Training Plan
        </h4>
        <button class="btn btn-sm btn-outline-secondary" @onclick="OpenSettings">
            <i class="fas fa-sliders-h me-1"></i>Settings
        </button>
    </div>

    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <a class="nav-link @(currentView == CalendarView.Overview ? "active" : "")" href="#" @onclick="() => currentView = CalendarView.Overview" @onclick:preventDefault>
                <i class="fas fa-list-alt me-1"></i>Overview
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(currentView == CalendarView.Monthly ? "active" : "")" href="#" @onclick="() => currentView = CalendarView.Monthly" @onclick:preventDefault>
                <i class="fas fa-calendar me-1"></i>Monthly
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(currentView == CalendarView.Weekly ? "active" : "")" href="#" @onclick="() => currentView = CalendarView.Weekly" @onclick:preventDefault>
                <i class="fas fa-calendar-week me-1"></i>Weekly
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(currentView == CalendarView.Daily ? "active" : "")" href="#" @onclick="() => currentView = CalendarView.Daily" @onclick:preventDefault>
                <i class="fas fa-calendar-day me-1"></i>Daily
            </a>
        </li>
    </ul>

    @switch (currentView)
    {
        case CalendarView.Monthly:
            <MonthlyCalendarView Plan="PlanState.ActivePlan" @bind-SelectedDate="selectedDate" />
            break;
        case CalendarView.Weekly:
            <WeeklyCalendarView Plan="PlanState.ActivePlan" CurrentDate="selectedDate" />
            break;
        case CalendarView.Daily:
            <DailyView Plan="PlanState.ActivePlan" Date="selectedDate"
                       OnPreviousDay="() => selectedDate = selectedDate.AddDays(-1)"
                       OnNextDay="() => selectedDate = selectedDate.AddDays(1)"
                       OnWorkoutChanged="StateHasChanged" />
            break;
        case CalendarView.Overview:
            <PlanOverviewView Plan="PlanState.ActivePlan" />
            break;
    }

    @* --- Discreet action links --- *@
    <div class="mt-4 d-flex justify-content-between align-items-center">
        <div class="d-flex gap-3">
            @if (activeInjury == null && !showInjuryFlow)
            {
                <button class="btn btn-sm btn-link text-muted" @onclick="() => showInjuryFlow = true">
                    <i class="fas fa-band-aid me-1"></i>Report an injury
                </button>
            }
            @if (!showVacation)
            {
                <button class="btn btn-sm btn-link text-muted" @onclick="() => showVacation = true">
                    <i class="fas fa-umbrella-beach me-1"></i>Schedule vacation
                </button>
            }
        </div>
        <div class="dropdown">
            <button class="btn btn-sm btn-link text-muted dropdown-toggle" type="button" data-bs-toggle="dropdown">
                <i class="fas fa-ellipsis-h me-1"></i>Plan Options
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
                <li><button class="dropdown-item" @onclick="HandlePause"><i class="fas fa-pause me-2"></i>Pause Plan</button></li>
                <li><hr class="dropdown-divider" /></li>
                <li><button class="dropdown-item text-danger" @onclick="() => showAbandonConfirm = true"><i class="fas fa-times me-2"></i>Abandon Plan</button></li>
            </ul>
        </div>
    </div>

    @if (showAbandonConfirm)
    {
        <div class="alert alert-secondary mt-3">
            <p class="mb-2">Are you sure you want to abandon this plan? It will be archived.</p>
            <button class="btn btn-sm btn-danger me-2" @onclick="HandleAbandon">Yes, Archive Plan</button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="() => showAbandonConfirm = false">Cancel</button>
        </div>
    }

    @if (showInjuryFlow)
    {
        <div class="mt-3">
            <ReportInjuryFlow OnReport="HandleInjuryReport" OnCancel="() => showInjuryFlow = false" />
        </div>
    }

    @if (showVacation)
    {
        <div class="mt-3">
            <VacationEntry Plan="PlanState.ActivePlan!" IsPaidUser="true"
                           OnApplied="HandleVacationApplied" OnCancel="() => showVacation = false" />
        </div>
    }

    @* --- Settings slide-out --- *@
    @if (showSettings)
    {
        <div class="position-fixed top-0 start-0 w-100 h-100" style="background: rgba(0,0,0,0.3); z-index: 1040;"
             @onclick="() => showSettings = false"></div>

        <div class="position-fixed top-0 end-0 h-100 bg-white shadow" style="z-index: 1050; width: 360px; overflow-y: auto;"
             @onclick:stopPropagation="true">
            <div class="p-3">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0"><i class="fas fa-sliders-h me-2"></i>Settings</h5>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => showSettings = false">
                        <i class="fas fa-times"></i>
                    </button>
                </div>

                @if (settingsProfile != null)
                {
                    @if (settingsSaved)
                    {
                        <div class="alert alert-success py-1 small">
                            <i class="fas fa-check me-1"></i>Saved — plan updated.
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Experience Level</label>
                        <select class="form-select form-select-sm" @bind="settingsProfile.ExperienceLevel">
                            @foreach (var level in Enum.GetValues<ExperienceLevel>())
                            {
                                <option value="@level">@level</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Pace Guidance</label>
                        <select class="form-select form-select-sm" @bind="settingsProfile.PacePreference">
                            <option value="@PacePreference.RPE">RPE (Effort-Based)</option>
                            <option value="@PacePreference.VDOT">VDOT (Pace-Based)</option>
                        </select>
                    </div>

                    @if (settingsProfile.PacePreference == PacePreference.VDOT)
                    {
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">VDOT Value</label>
                            <input type="number" class="form-control form-control-sm" step="0.1" min="20" max="85"
                                   @bind="settingsProfile.VdotValue" placeholder="e.g. 45" />
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Available Days</label>
                        <div class="d-flex gap-1 flex-wrap">
                            @foreach (var day in settingsAllDays)
                            {
                                var d = day;
                                var sel = settingsSelectedDays.Contains(d);
                                <button class="btn btn-sm @(sel ? "btn-primary" : "btn-outline-secondary")"
                                        style="min-width: 42px;"
                                        @onclick="() => ToggleSettingsDay(d)">
                                    @d.ToString()[..2]
                                </button>
                            }
                        </div>
                        @if (settingsSelectedDays.Count < 3)
                        {
                            <small class="text-danger">Select at least 3 days</small>
                        }
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold small">Long Run Day</label>
                        <div class="d-flex gap-1 flex-wrap">
                            @foreach (var day in settingsSelectedDays.OrderBy(d => d))
                            {
                                var d = day;
                                var isLongRun = settingsProfile.PreferredLongRunDay == d;
                                <button class="btn btn-sm @(isLongRun ? "btn-success" : "btn-outline-secondary")"
                                        style="min-width: 42px;"
                                        @onclick="() => settingsProfile.PreferredLongRunDay = d">
                                    @d.ToString()[..2]
                                    @if (isLongRun) { <i class="fas fa-running ms-1"></i> }
                                </button>
                            }
                        </div>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <label class="form-label fw-semibold small">Weekly Miles</label>
                            <input type="number" class="form-control form-control-sm" step="1" min="0" max="200"
                                   @bind="settingsProfile.CurrentWeeklyMileage" placeholder="optional" />
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-semibold small">Experience (mo)</label>
                            <input type="number" class="form-control form-control-sm" step="1" min="0"
                                   @bind="settingsProfile.RunningExperienceMonths" placeholder="optional" />
                        </div>
                    </div>

                    <button class="btn btn-primary w-100" @onclick="SaveSettingsPanel" disabled="@(settingsSelectedDays.Count < 3)">
                        <i class="fas fa-save me-1"></i>Apply Changes
                    </button>
                }
            </div>
        </div>
    }
}

@code {
    private CalendarView currentView = CalendarView.Overview;
    private DateTime selectedDate = DateTime.Today;

    // Injury state
    private InjuryReport? activeInjury;
    private bool showInjuryFlow;
    private bool showUpdateInjury;
    private int updateSeverity = 3;

    // Plan management state
    private bool showVacation;
    private bool showAbandonConfirm;
    private bool isRecurringInjury;

    // Settings slide-out state
    private bool showSettings;
    private UserProfile? settingsProfile;
    private List<DayOfWeek> settingsSelectedDays = new();
    private bool settingsSaved;
    private static readonly DayOfWeek[] settingsAllDays =
    [
        DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday,
        DayOfWeek.Thursday, DayOfWeek.Friday, DayOfWeek.Saturday, DayOfWeek.Sunday
    ];

    protected override void OnInitialized()
    {
        AuthState.OnAuthStateChanged += HandleStateChanged;
        PlanState.OnPlanChanged += HandlePlanChanged;
    }

    private async Task HandlePlanChanged()
    {
        await LoadActiveInjury();
        await InvokeAsync(StateHasChanged);
    }

    private Task HandleStateChanged() => InvokeAsync(StateHasChanged);

    private async Task LoadActiveInjury()
    {
        if (AuthState.CurrentUser == null) return;
        var injuries = await WorkoutRepo.GetActiveInjuriesAsync(AuthState.CurrentUser.Id);
        activeInjury = injuries.FirstOrDefault();

        if (activeInjury != null)
        {
            var allInjuries = await WorkoutRepo.GetAllInjuriesAsync(AuthState.CurrentUser.Id);
            isRecurringInjury = InjuryEngine.IsRecurring(activeInjury.BodyPart, allInjuries);
        }
    }

    private async Task HandleInjuryReport(InjuryReport report)
    {
        if (AuthState.CurrentUser == null) return;
        report.UserId = AuthState.CurrentUser.Id;
        await WorkoutRepo.SaveInjuryReportAsync(report);

        // Apply modifications to future workouts
        if (PlanState.ActivePlan != null)
        {
            InjuryEngine.ApplyToFutureWorkouts(PlanState.ActivePlan, report.Severity);
            foreach (var workout in PlanState.ActivePlan.Weeks.SelectMany(w => w.Workouts)
                         .Where(w => w.Date.Date >= DateTime.Today && w.Id > 0))
            {
                await WorkoutRepo.UpdateWorkoutAsync(workout);
            }
        }

        activeInjury = report;
        showInjuryFlow = false;
    }

    private void ShowUpdateInjury()
    {
        updateSeverity = activeInjury?.Severity ?? 3;
        showUpdateInjury = true;
    }

    private async Task SubmitInjuryUpdate()
    {
        if (activeInjury == null) return;
        activeInjury.Severity = updateSeverity;
        activeInjury.PainHistory.Add(new PainEntry { Severity = updateSeverity, InjuryReportId = activeInjury.Id });
        await WorkoutRepo.SaveInjuryReportAsync(activeInjury);

        // Re-apply with updated severity
        if (PlanState.ActivePlan != null)
        {
            InjuryEngine.ApplyToFutureWorkouts(PlanState.ActivePlan, updateSeverity);
            foreach (var workout in PlanState.ActivePlan.Weeks.SelectMany(w => w.Workouts)
                         .Where(w => w.Date.Date >= DateTime.Today && w.Id > 0))
            {
                await WorkoutRepo.UpdateWorkoutAsync(workout);
            }
        }

        showUpdateInjury = false;
    }

    private async Task ResolveInjury()
    {
        if (activeInjury == null) return;
        activeInjury.Status = InjuryStatus.Resolved;
        await WorkoutRepo.SaveInjuryReportAsync(activeInjury);

        // Apply return progression
        if (PlanState.ActivePlan != null)
        {
            var currentWeek = PlanState.ActivePlan.CurrentWeek;
            if (currentWeek != null)
            {
                InjuryEngine.ApplyReturnProgression(PlanState.ActivePlan, currentWeek.WeekNumber);
                foreach (var workout in PlanState.ActivePlan.Weeks.SelectMany(w => w.Workouts)
                             .Where(w => w.Date.Date >= DateTime.Today && w.Id > 0))
                {
                    await WorkoutRepo.UpdateWorkoutAsync(workout);
                }
            }
        }

        activeInjury = null;
    }

    private string? GetPhaseTransitionMessage()
    {
        if (PlanState.ActivePlan == null) return null;
        var currentWeek = PlanState.ActivePlan.CurrentWeek;
        if (currentWeek == null || currentWeek.WeekNumber <= 1) return null;

        var previousWeek = PlanState.ActivePlan.Weeks.FirstOrDefault(w => w.WeekNumber == currentWeek.WeekNumber - 1);
        if (previousWeek != null && previousWeek.Phase != currentWeek.Phase)
        {
            return MessagingService.GetPhaseTransitionMessage(currentWeek.Phase);
        }
        return null;
    }

    private string? GetMilestoneMessage()
    {
        if (PlanState.ActivePlan == null) return null;
        var completed = PlanState.ActivePlan.CompletedWorkouts;
        var msg = MessagingService.GetMilestoneMessage(completed);
        return string.IsNullOrEmpty(msg) ? null : msg;
    }

    private int CalculateStreak()
    {
        if (PlanState.ActivePlan == null) return 0;
        var allWorkouts = PlanState.ActivePlan.Weeks
            .SelectMany(w => w.Workouts)
            .Where(w => w.IsRunWorkout)
            .OrderByDescending(w => w.Date)
            .ToList();

        int streak = 0;
        foreach (var w in allWorkouts)
        {
            if (w.Date.Date > DateTime.Today) continue;
            if (w.Status == WorkoutStatus.Completed) streak++;
            else break;
        }
        return streak;
    }

    private bool IsPlanComplete()
    {
        if (PlanState.ActivePlan == null) return false;
        var plan = PlanState.ActivePlan;
        if (plan.Status == PlanStatus.Completed) return false; // already handled
        var lastWorkoutDate = plan.Weeks.SelectMany(w => w.Workouts).Max(w => w.Date);
        return lastWorkoutDate.Date < DateTime.Today;
    }

    private ScheduledWorkout? GetTodayWorkout() =>
        PlanState.ActivePlan?.Weeks.SelectMany(w => w.Workouts).FirstOrDefault(w => w.Date.Date == DateTime.Today);

    private async Task QuickCompleteTodayWidget(ScheduledWorkout workout)
    {
        LoggingService.QuickComplete(workout);
        await WorkoutRepo.UpdateWorkoutAsync(workout);
        StateHasChanged();
    }

    private void GoToToday()
    {
        selectedDate = DateTime.Today;
        currentView = CalendarView.Daily;
    }

    private async Task HandlePause()
    {
        await PlanState.PausePlanAsync();
    }

    private async Task HandleResume()
    {
        await PlanState.ResumePlanAsync();
    }

    private async Task HandleAbandon()
    {
        showAbandonConfirm = false;
        await PlanState.AbandonPlanAsync();
        Navigation.NavigateTo("/");
    }

    private async Task HandleVacationApplied((DateTime Start, DateTime End) range)
    {
        // Persist modified workouts
        if (PlanState.ActivePlan != null)
        {
            foreach (var workout in PlanState.ActivePlan.Weeks.SelectMany(w => w.Workouts)
                         .Where(w => w.Date.Date >= range.Start.Date && w.Date.Date <= range.End.Date && w.Id > 0))
            {
                await WorkoutRepo.UpdateWorkoutAsync(workout);
            }
        }
        showVacation = false;
    }

    private async Task OpenSettings()
    {
        if (AuthState.CurrentUser != null)
        {
            settingsProfile = await UserService.GetOrCreateProfileAsync(AuthState.CurrentUser.Id);
            settingsSelectedDays = settingsProfile.AvailableDays.ToList();
            settingsSaved = false;
        }
        showSettings = true;
    }

    private void ToggleSettingsDay(DayOfWeek day)
    {
        if (settingsSelectedDays.Contains(day))
            settingsSelectedDays.Remove(day);
        else
            settingsSelectedDays.Add(day);
    }

    private async Task SaveSettingsPanel()
    {
        if (settingsProfile == null || settingsSelectedDays.Count < 3) return;

        var oldDays = settingsProfile.AvailableDays;
        settingsProfile.AvailableDays = settingsSelectedDays.OrderBy(d => d).ToArray();
        await UserService.SaveProfileAsync(settingsProfile);

        PlanState.UpdateUserProfile(settingsProfile);

        // Reflow if days changed
        if (PlanState.HasActivePlan && !oldDays.SequenceEqual(settingsProfile.AvailableDays))
        {
            FlexEngine.ReflowRemainingWeeks(PlanState.ActivePlan!, settingsProfile.AvailableDays);

            foreach (var workout in PlanState.ActivePlan!.Weeks.SelectMany(w => w.Workouts)
                         .Where(w => w.Date.Date >= DateTime.Today && w.Id > 0))
            {
                await WorkoutRepo.UpdateWorkoutAsync(workout);
            }
        }

        settingsSaved = true;
        StateHasChanged();
        await Task.Delay(2000);
        settingsSaved = false;
        StateHasChanged();
    }

    private static string FormatBodyPart(BodyPart part) => part switch
    {
        BodyPart.ITBand => "IT Band",
        _ => part.ToString()
    };

    public void Dispose()
    {
        AuthState.OnAuthStateChanged -= HandleStateChanged;
        PlanState.OnPlanChanged -= HandlePlanChanged;
    }

    public enum CalendarView { Monthly, Weekly, Daily, Overview }
}
