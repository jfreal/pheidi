@page "/calendar"
@rendermode InteractiveServer
@implements IDisposable
@using Pheidi.Blazor.Services
@inject PlanStateService PlanState
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Pheidi - Training Calendar</PageTitle>

@if (!AuthState.IsAuthenticated)
{
    <div class="text-center mt-5">
        <h4>Sign in to view your calendar</h4>
        <p class="text-muted">You need to be signed in to access your training plan.</p>
        <a href="/signin" class="btn btn-primary"><i class="fas fa-user me-2"></i>Sign In</a>
    </div>
}
else if (!PlanState.HasActivePlan)
{
    <div class="text-center mt-5">
        <h4>No active training plan</h4>
        <p class="text-muted">Set up your training plan to see your calendar.</p>
        <a href="/setup" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Create a Plan</a>
    </div>
}
else
{
    <h4 class="mt-3 mb-3">
        <i class="far fa-calendar-alt"></i>
        @PlanState.ActivePlan!.RaceGoal.Distance.DisplayName() Training Plan
    </h4>

    <ul class="nav nav-tabs mb-3">
        <li class="nav-item">
            <a class="nav-link @(currentView == CalendarView.Overview ? "active" : "")" href="#" @onclick="() => currentView = CalendarView.Overview" @onclick:preventDefault>
                <i class="fas fa-list-alt me-1"></i>Overview
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(currentView == CalendarView.Monthly ? "active" : "")" href="#" @onclick="() => currentView = CalendarView.Monthly" @onclick:preventDefault>
                <i class="fas fa-calendar me-1"></i>Monthly
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(currentView == CalendarView.Weekly ? "active" : "")" href="#" @onclick="() => currentView = CalendarView.Weekly" @onclick:preventDefault>
                <i class="fas fa-calendar-week me-1"></i>Weekly
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(currentView == CalendarView.Daily ? "active" : "")" href="#" @onclick="() => currentView = CalendarView.Daily" @onclick:preventDefault>
                <i class="fas fa-calendar-day me-1"></i>Daily
            </a>
        </li>
    </ul>

    @switch (currentView)
    {
        case CalendarView.Monthly:
            <MonthlyCalendarView Plan="PlanState.ActivePlan" @bind-SelectedDate="selectedDate" />
            break;
        case CalendarView.Weekly:
            <WeeklyCalendarView Plan="PlanState.ActivePlan" CurrentDate="selectedDate" />
            break;
        case CalendarView.Daily:
            <DailyView Plan="PlanState.ActivePlan" Date="selectedDate"
                       OnPreviousDay="() => selectedDate = selectedDate.AddDays(-1)"
                       OnNextDay="() => selectedDate = selectedDate.AddDays(1)" />
            break;
        case CalendarView.Overview:
            <PlanOverviewView Plan="PlanState.ActivePlan" />
            break;
    }
}

@code {
    private CalendarView currentView = CalendarView.Overview;
    private DateTime selectedDate = DateTime.Today;

    protected override void OnInitialized()
    {
        AuthState.OnAuthStateChanged += HandleAuthStateChanged;
    }

    private void HandleAuthStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        AuthState.OnAuthStateChanged -= HandleAuthStateChanged;
    }

    public enum CalendarView { Monthly, Weekly, Daily, Overview }
}
