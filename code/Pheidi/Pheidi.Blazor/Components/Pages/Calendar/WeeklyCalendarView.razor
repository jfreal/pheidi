@using Pheidi.Blazor.Components.Shared
@using Pheidi.Blazor.Services
@using Pheidi.Common.Engines
@using Pheidi.Common.Services
@inject PaceCalculator PaceCalc
@inject PlanStateService PlanState
@inject WorkoutRepository WorkoutRepo

<div class="d-flex justify-content-between align-items-center mb-3">
    <button class="btn btn-sm btn-outline-secondary" @onclick="PreviousWeek">
        <i class="fas fa-chevron-left"></i>
    </button>
    <h5 class="mb-0">Week of @weekStart.ToString("MMM d") — @weekStart.AddDays(6).ToString("MMM d, yyyy")</h5>
    <button class="btn btn-sm btn-outline-secondary" @onclick="NextWeek">
        <i class="fas fa-chevron-right"></i>
    </button>
</div>

@{
    var trainingWeek = GetTrainingWeek();
}

@if (trainingWeek != null)
{
    <div class="mb-2">
        <span class="badge" style="background-color: @PhaseColor(trainingWeek.Phase); color: #fff;">
            @trainingWeek.Phase Phase
        </span>
        <span class="text-muted ms-2">Week @trainingWeek.WeekNumber — @trainingWeek.TotalPlannedDistance.ToString("F1") mi total</span>
    </div>
}

<div class="row g-3">
    @for (int d = 0; d < 7; d++)
    {
        var date = weekStart.AddDays(d);
        var workout = GetWorkout(date);
        var isToday = date.Date == DateTime.Today;

        <div class="col-12">
            <div class="card @(isToday ? "border-primary" : "") @(workout?.Status == WorkoutStatus.Skipped ? "opacity-50" : "") @(dragOverDate == date.Date ? "border-warning border-2" : "")"
                 draggable="@(workout != null && workout.Status == WorkoutStatus.Pending ? "true" : "false")"
                 @ondragstart="() => HandleDragStart(workout)"
                 @ondragover:preventDefault
                 @ondragover="() => dragOverDate = date.Date"
                 @ondragleave="() => { if (dragOverDate == date.Date) dragOverDate = null; }"
                 @ondrop="() => HandleDrop(workout)"
                 style="@(workout != null && workout.Status == WorkoutStatus.Pending ? "cursor: grab;" : "")">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="mb-1 @(isToday ? "text-primary fw-bold" : "")">
                                @date.ToString("dddd, MMM d")
                                @if (isToday)
                                {
                                    <span class="badge bg-primary ms-1">Today</span>
                                }
                                @if (workout?.Status == WorkoutStatus.Completed)
                                {
                                    <i class="fas fa-check-circle text-success ms-1" title="Completed"></i>
                                }
                                else if (workout?.Status == WorkoutStatus.Skipped)
                                {
                                    <i class="fas fa-forward text-muted ms-1" title="Skipped"></i>
                                }
                            </h6>
                            @if (workout != null && workout.Modifier != WorkoutModifier.None)
                            {
                                <span class="badge me-2" style="background-color: @WorkoutColors.GetModifier(workout.Modifier); color: @WorkoutColors.GetModifierText(workout.Modifier);">
                                    <i class="@WorkoutColors.GetModifierIcon(workout.Modifier) me-1"></i>@(workout.Modifier switch { WorkoutModifier.Vacation => "Vacation", WorkoutModifier.DayOff => "Day Off", _ => "Injury" })
                                </span>
                                <span>@workout.Description</span>
                            }
                            else if (workout != null && workout.Type != WorkoutType.Rest)
                            {
                                <span class="badge me-2" style="background-color: @WorkoutColors.Get(workout.Type); color: @WorkoutColors.GetText(workout.Type);">
                                    @workout.Type
                                </span>
                                <span class="@(workout.Status == WorkoutStatus.Skipped ? "text-decoration-line-through text-muted" : "")">
                                    @workout.Description
                                </span>

                                @if (workout.PaceZone != null)
                                {
                                    <div class="small text-muted mt-1">
                                        <i class="fas fa-heartbeat"></i> @workout.PaceZone.RpeDescription
                                        (RPE @workout.PaceZone.RpeMin-@workout.PaceZone.RpeMax)
                                    </div>
                                    @if (GetVdotPace(workout) is { } vdotPace)
                                    {
                                        <div class="small text-primary mt-1">
                                            <i class="fas fa-tachometer-alt"></i> @vdotPace
                                        </div>
                                    }
                                }
                                @if (workout.WarmUpDuration.HasValue)
                                {
                                    <div class="small text-muted">
                                        <i class="fas fa-fire"></i> Warm up: @((int)workout.WarmUpDuration.Value.TotalMinutes) min
                                        &nbsp;|&nbsp;
                                        <i class="fas fa-snowflake"></i> Cool down: @((int)(workout.CoolDownDuration?.TotalMinutes ?? 0)) min
                                    </div>
                                }
                            }
                            else
                            {
                                <span class="text-muted">Rest Day</span>
                            }
                        </div>
                        @if (workout != null && workout.Type != WorkoutType.Rest)
                        {
                            <div class="text-end">
                                <span class="fs-4 fw-bold">@workout.TargetDistanceMiles.ToString("F1")</span>
                                <small class="text-muted d-block">miles</small>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public NewTrainingPlan Plan { get; set; } = default!;

    [Parameter]
    public DateTime CurrentDate { get; set; } = DateTime.Today;

    private DateTime weekStart;
    private ScheduledWorkout? _dragSource;
    private DateTime? dragOverDate;
    private string? swapMessage;

    protected override void OnInitialized() => CalculateWeekStart();
    protected override void OnParametersSet() => CalculateWeekStart();

    private void CalculateWeekStart()
    {
        var daysSinceMonday = ((int)CurrentDate.DayOfWeek + 6) % 7;
        weekStart = CurrentDate.AddDays(-daysSinceMonday);
    }

    private void PreviousWeek() => weekStart = weekStart.AddDays(-7);
    private void NextWeek() => weekStart = weekStart.AddDays(7);

    private ScheduledWorkout? GetWorkout(DateTime date) =>
        Plan.Weeks.SelectMany(w => w.Workouts).FirstOrDefault(w => w.Date.Date == date.Date);

    private TrainingWeek? GetTrainingWeek() =>
        Plan.Weeks.FirstOrDefault(w => w.Workouts.Any(wo => wo.Date.Date >= weekStart && wo.Date.Date <= weekStart.AddDays(6)));

    private string? GetVdotPace(ScheduledWorkout workout)
    {
        var profile = PlanState.UserProfile;
        if (profile.PacePreference != PacePreference.VDOT || !profile.VdotValue.HasValue || workout.PaceZone == null)
            return null;

        var zone = PaceCalc.GetPaceZone(workout.PaceZone.Zone, profile.VdotValue.Value);
        if (zone.MinPacePerMile == null || zone.MaxPacePerMile == null) return null;
        return $"{PaceCalculator.FormatPace(zone.MinPacePerMile.Value)} - {PaceCalculator.FormatPace(zone.MaxPacePerMile.Value)} /mi";
    }

    private void HandleDragStart(ScheduledWorkout? workout) => _dragSource = workout;

    private async Task HandleDrop(ScheduledWorkout? target)
    {
        dragOverDate = null;
        if (_dragSource == null || target == null || _dragSource == target) return;

        var week = GetTrainingWeek();
        if (week == null) return;

        // Validate swap won't create consecutive hard days
        if (!ScheduleFlexibilityEngine.ValidateSwap(week, _dragSource, target))
        {
            swapMessage = "Can't swap — would create consecutive hard days.";
            _dragSource = null;
            StateHasChanged();
            await Task.Delay(2000);
            swapMessage = null;
            return;
        }

        ScheduleFlexibilityEngine.SwapWorkouts(_dragSource, target);

        // Persist both workouts
        if (_dragSource.Id > 0) await WorkoutRepo.UpdateWorkoutAsync(_dragSource);
        if (target.Id > 0) await WorkoutRepo.UpdateWorkoutAsync(target);

        _dragSource = null;
    }

    private static string PhaseColor(TrainingPhase phase) => phase switch
    {
        TrainingPhase.Base => "#81C784",
        TrainingPhase.Build => "#FFB74D",
        TrainingPhase.Peak => "#E57373",
        TrainingPhase.Taper => "#64B5F6",
        _ => "#9E9E9E"
    };
}
