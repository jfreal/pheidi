@using Pheidi.Blazor.Components.Shared
@using Pheidi.Blazor.Components.Shared.Logging
@using Pheidi.Blazor.Services
@using Pheidi.Common.Services
@inject WorkoutRepository WorkoutRepo

<div class="d-flex justify-content-between align-items-center mb-3">
    <button class="btn btn-sm btn-outline-secondary" @onclick="PreviousMonth">
        <i class="fas fa-chevron-left"></i>
    </button>
    <h5 class="mb-0">@displayMonth.ToString("MMMM yyyy")</h5>
    <button class="btn btn-sm btn-outline-secondary" @onclick="NextMonth">
        <i class="fas fa-chevron-right"></i>
    </button>
</div>

<div class="calendar-grid">
    <div class="row calendar-header">
        @foreach (var day in new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" })
        {
            <div class="col text-center fw-bold small text-muted py-2">@day</div>
        }
    </div>

    @foreach (var weekRow in GetCalendarWeeks())
    {
        <div class="row calendar-week">
            @foreach (var date in weekRow)
            {
                var d = date;
                var workout = GetWorkout(d);
                var isToday = d.Date == DateTime.Today;
                var isCurrentMonth = d.Month == displayMonth.Month;
                var isSelected = d.Date == SelectedDate.Date;

                <div class="col calendar-day @(isToday ? "today" : "") @(!isCurrentMonth ? "other-month" : "") @(isSelected ? "selected" : "")"
                     @onclick="() => SelectDate(d)">
                    <div class="day-number @(isToday ? "fw-bold" : "")">@d.Day</div>
                    @if (workout != null && workout.Type != WorkoutType.Rest)
                    {
                        <div class="workout-badge" style="background-color: @WorkoutColors.Get(workout.Type);">
                            <small>@WorkoutShortName(workout.Type)</small>
                        </div>
                        <div class="workout-distance small">@workout.TargetDistanceMiles.ToString("F1") mi</div>
                        @if (workout.Status == WorkoutStatus.Completed)
                        {
                            <i class="fas fa-check-circle text-success" style="font-size: 0.7rem;"></i>
                        }
                        else if (workout.Status == WorkoutStatus.Skipped)
                        {
                            <i class="fas fa-forward text-muted" style="font-size: 0.7rem;"></i>
                        }
                    }
                    else if (workout?.Type == WorkoutType.Rest)
                    {
                        <div class="workout-rest small text-muted">Rest</div>
                    }
                </div>
            }
        </div>
    }
</div>

@if (_detailWorkout != null)
{
    <div class="position-fixed top-0 start-0 w-100 h-100"
         style="background: rgba(0,0,0,0.3); z-index: 1040;"
         @onclick="CloseDetail"></div>

    <div class="position-fixed top-50 start-50 translate-middle card shadow"
         style="z-index: 1050; width: 350px; max-height: 80vh; overflow-y: auto;"
         @onclick:stopPropagation="true">
        <div class="card-header d-flex justify-content-between align-items-center"
             style="background-color: @WorkoutColors.Get(_detailWorkout.Type); color: @WorkoutColors.GetText(_detailWorkout.Type);">
            <h6 class="mb-0">@_detailWorkout.Date.ToString("ddd, MMM d")</h6>
            <button class="btn btn-sm btn-close btn-close-white" @onclick="CloseDetail"></button>
        </div>
        <div class="card-body">
            <h5>@_detailWorkout.Type</h5>
            <p class="mb-1">@_detailWorkout.Description</p>
            @if (_detailWorkout.PaceZone != null)
            {
                <div class="small text-muted mb-2">
                    <i class="fas fa-heartbeat me-1"></i>@_detailWorkout.PaceZone.RpeDescription
                    (RPE @_detailWorkout.PaceZone.RpeMin-@_detailWorkout.PaceZone.RpeMax)
                </div>
            }
            @if (_detailWorkout.WarmUpDuration.HasValue)
            {
                <div class="small text-muted">
                    <i class="fas fa-fire me-1"></i>Warm up: @((int)_detailWorkout.WarmUpDuration.Value.TotalMinutes) min
                    | Cool down: @((int)(_detailWorkout.CoolDownDuration?.TotalMinutes ?? 0)) min
                </div>
            }

            @if (_detailWorkout.Status == WorkoutStatus.Completed)
            {
                <div class="alert alert-success py-2 mt-2 mb-0">
                    <i class="fas fa-check-circle me-1"></i> Completed
                    @if (_detailWorkout.ActualDistanceMiles.HasValue)
                    {
                        <span class="ms-1">@_detailWorkout.ActualDistanceMiles.Value.ToString("F1") mi</span>
                    }
                </div>
            }
            else if (_detailWorkout.Status == WorkoutStatus.Skipped)
            {
                <div class="alert alert-secondary py-2 mt-2 mb-0">
                    <i class="fas fa-forward me-1"></i> Skipped
                </div>
            }
            else if (_detailWorkout.Status == WorkoutStatus.Pending && _detailWorkout.IsRunWorkout)
            {
                <hr />
                <QuickCompleteButton Workout="_detailWorkout" OnCompleted="() => HandleQuickComplete(_detailWorkout)" />
            }
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public NewTrainingPlan Plan { get; set; } = default!;

    [Parameter]
    public DateTime SelectedDate { get; set; } = DateTime.Today;

    [Parameter]
    public EventCallback<DateTime> SelectedDateChanged { get; set; }

    private DateTime displayMonth;
    private ScheduledWorkout? _detailWorkout;

    protected override void OnInitialized()
    {
        displayMonth = new DateTime(SelectedDate.Year, SelectedDate.Month, 1);
    }

    private void PreviousMonth() => displayMonth = displayMonth.AddMonths(-1);
    private void NextMonth() => displayMonth = displayMonth.AddMonths(1);

    private async Task SelectDate(DateTime date)
    {
        SelectedDate = date;
        await SelectedDateChanged.InvokeAsync(date);

        // Show detail panel if there's a non-rest workout
        var workout = GetWorkout(date);
        _detailWorkout = workout?.Type != WorkoutType.Rest ? workout : null;
    }

    private ScheduledWorkout? GetWorkout(DateTime date) =>
        Plan.Weeks.SelectMany(w => w.Workouts).FirstOrDefault(w => w.Date.Date == date.Date);

    private List<DateTime[]> GetCalendarWeeks()
    {
        var weeks = new List<DateTime[]>();
        var firstOfMonth = new DateTime(displayMonth.Year, displayMonth.Month, 1);
        var startDay = firstOfMonth.AddDays(-((int)firstOfMonth.DayOfWeek + 6) % 7);

        for (var weekStart = startDay; weekStart.Month <= displayMonth.Month || weekStart < firstOfMonth.AddMonths(1); weekStart = weekStart.AddDays(7))
        {
            var week = new DateTime[7];
            for (int d = 0; d < 7; d++)
                week[d] = weekStart.AddDays(d);
            weeks.Add(week);
            if (weekStart.AddDays(7).Month > displayMonth.Month && weekStart.AddDays(7).Year >= displayMonth.Year)
                break;
        }

        return weeks;
    }

    private static string WorkoutShortName(WorkoutType type) => type switch
    {
        WorkoutType.Easy => "Easy",
        WorkoutType.Tempo => "Tempo",
        WorkoutType.Intervals => "Int",
        WorkoutType.LongRun => "Long",
        WorkoutType.Recovery => "Rec",
        WorkoutType.Fartlek => "Fart",
        WorkoutType.HillRepeats => "Hills",
        WorkoutType.RacePace => "Race",
        WorkoutType.CrossTraining => "XT",
        WorkoutType.Strength => "Str",
        _ => ""
    };

    private void CloseDetail() => _detailWorkout = null;

    private async Task HandleQuickComplete(ScheduledWorkout workout)
    {
        var service = new WorkoutLoggingService();
        service.QuickComplete(workout);
        await WorkoutRepo.UpdateWorkoutAsync(workout);
        _detailWorkout = null;
    }
}
