@using Pheidi.Blazor.Components.Shared
@using Pheidi.Blazor.Services
@inject WorkoutRepository WorkoutRepo

<div class="d-flex gap-3 mb-3 flex-wrap">
    <span><span class="badge" style="background-color: #81C784;">&nbsp;</span> Base</span>
    <span><span class="badge" style="background-color: #FFB74D;">&nbsp;</span> Build</span>
    <span><span class="badge" style="background-color: #E57373;">&nbsp;</span> Peak</span>
    <span><span class="badge" style="background-color: #64B5F6;">&nbsp;</span> Taper</span>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card text-center">
            <div class="card-body py-2">
                <div class="fs-4 fw-bold">@Plan.TotalWeeks</div>
                <small class="text-muted">Weeks</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center">
            <div class="card-body py-2">
                <div class="fs-4 fw-bold">@Plan.TotalPlannedMiles.ToString("F0")</div>
                <small class="text-muted">Total Miles</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center">
            <div class="card-body py-2">
                <div class="fs-4 fw-bold">@Plan.PeakWeeklyMiles.ToString("F0")</div>
                <small class="text-muted">Peak Week</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card text-center">
            <div class="card-body py-2">
                <div class="fs-4 fw-bold">@Plan.LongestRun.ToString("F0")</div>
                <small class="text-muted">Longest Run</small>
            </div>
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-sm table-bordered align-middle" style="font-size: 0.85rem;">
        <thead class="table-light">
            <tr>
                <th style="width: 50px;">Wk</th>
                <th style="width: 60px;">Phase</th>
                @foreach (var day in weekDays)
                {
                    <th class="text-center">@day.ToString()[..3]</th>
                }
                <th class="text-end" style="width: 70px;">Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var week in Plan.Weeks)
            {
                var isCurrentWeek = week == Plan.CurrentWeek;
                <tr class="@(isCurrentWeek ? "table-warning" : "")"
                    style="border-left: 4px solid @PhaseColor(week.Phase);">
                    <td class="fw-bold">
                        @week.WeekNumber
                        @if (isCurrentWeek)
                        {
                            <i class="fas fa-caret-left text-primary"></i>
                        }
                    </td>
                    <td>
                        <span class="badge" style="background-color: @PhaseColor(week.Phase); color: #fff; font-size: 0.7rem;">
                            @week.Phase.ToString()[..3]
                        </span>
                    </td>
                    @foreach (var day in weekDays)
                    {
                        var workout = week.Workouts.FirstOrDefault(w => w.Date.DayOfWeek == day);
                        <td class="text-center p-1" style="cursor: pointer;"
                            @onclick="@(() => { if (workout != null) OpenEdit(workout); })">
                            @if (workout != null && workout.Type != WorkoutType.Rest)
                            {
                                <div>
                                    <span class="badge d-block mb-0" style="background-color: @WorkoutColors.Get(workout.Type); color: @WorkoutColors.GetText(workout.Type); font-size: 0.7rem;">
                                        @ShortType(workout.Type)
                                    </span>
                                    @if (workout.TargetDistanceMiles > 0)
                                    {
                                        <small class="text-muted">@workout.TargetDistanceMiles.ToString("F1")</small>
                                    }
                                </div>
                            }
                            else if (workout != null)
                            {
                                <small class="text-muted">Rest</small>
                            }
                        </td>
                    }
                    <td class="text-end fw-bold">@week.TotalPlannedDistance.ToString("F1")</td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr class="table-light fw-bold">
                <td colspan="2">Total</td>
                <td colspan="7"></td>
                <td class="text-end">@Plan.TotalPlannedMiles.ToString("F1")</td>
            </tr>
        </tfoot>
    </table>
</div>

<h5 class="mt-4 mb-3">Weekly Summary</h5>
<div class="table-responsive">
    <table class="table table-sm table-hover">
        <thead class="table-light">
            <tr>
                <th>Week</th>
                <th>Phase</th>
                <th>Dates</th>
                <th>Long Run</th>
                <th>Key Workout</th>
                <th class="text-end">Total Miles</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var week in Plan.Weeks)
            {
                var isCurrentWeek = week == Plan.CurrentWeek;
                <tr class="@(isCurrentWeek ? "table-active fw-bold" : "")"
                    style="border-left: 4px solid @PhaseColor(week.Phase);">
                    <td>@week.WeekNumber</td>
                    <td>
                        <span class="badge" style="background-color: @PhaseColor(week.Phase); color: #fff;">
                            @week.Phase
                        </span>
                    </td>
                    <td>
                        @if (week.Workouts.Count > 0)
                        {
                            @week.WeekStartDate.ToString("MMM d")
                        }
                    </td>
                    <td>
                        @if (week.LongRunDistance > 0)
                        {
                            <span class="fw-bold">@week.LongRunDistance.ToString("F1") mi</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>
                        @{
                            var keyWorkout = week.Workouts.FirstOrDefault(w => w.IsQualityWorkout);
                        }
                        @if (keyWorkout != null)
                        {
                            <span class="badge" style="background-color: @WorkoutColors.Get(keyWorkout.Type); color: @WorkoutColors.GetText(keyWorkout.Type);">
                                @keyWorkout.Type
                            </span>
                            <span class="small">@keyWorkout.TargetDistanceMiles.ToString("F1") mi</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td class="text-end">@week.TotalPlannedDistance.ToString("F1")</td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr class="fw-bold">
                <td colspan="5">Total</td>
                <td class="text-end">@Plan.TotalPlannedMiles.ToString("F1") mi</td>
            </tr>
        </tfoot>
    </table>
</div>

@if (_editTarget != null)
{
    <div class="position-fixed top-0 start-0 w-100 h-100"
         style="background: rgba(0,0,0,0.3); z-index: 1040;"
         @onclick="CancelEdit"></div>

    <div class="position-fixed top-50 start-50 translate-middle card shadow"
         style="z-index: 1050; width: 280px;"
         @onclick:stopPropagation="true">
        <div class="card-body">
            <h6 class="card-title mb-3">
                Edit &mdash; @_editTarget.Date.ToString("ddd MMM d")
            </h6>

            <div class="mb-3">
                <label class="form-label small fw-semibold">Type</label>
                <select class="form-select form-select-sm" @bind="_editType">
                    @foreach (var wt in Enum.GetValues<WorkoutType>())
                    {
                        <option value="@wt">@wt</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label small fw-semibold">Distance (miles)</label>
                <input type="number" class="form-control form-control-sm"
                       step="0.1" min="0" max="50"
                       @bind="_editDistance" @bind:event="oninput" />
            </div>

            <div class="d-flex gap-2 justify-content-end">
                <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEdit">Cancel</button>
                <button class="btn btn-sm btn-primary" @onclick="SaveEdit">Save</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public NewTrainingPlan Plan { get; set; } = default!;

    private static readonly DayOfWeek[] weekDays =
    [
        DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday,
        DayOfWeek.Thursday, DayOfWeek.Friday, DayOfWeek.Saturday, DayOfWeek.Sunday
    ];

    private static string PhaseColor(TrainingPhase phase) => phase switch
    {
        TrainingPhase.Base => "#81C784",
        TrainingPhase.Build => "#FFB74D",
        TrainingPhase.Peak => "#E57373",
        TrainingPhase.Taper => "#64B5F6",
        _ => "#BDBDBD"
    };

    private static string ShortType(WorkoutType type) => type switch
    {
        WorkoutType.Easy => "Easy",
        WorkoutType.Tempo => "Tempo",
        WorkoutType.Intervals => "Int",
        WorkoutType.LongRun => "Long",
        WorkoutType.Recovery => "Rec",
        WorkoutType.Fartlek => "Fart",
        WorkoutType.HillRepeats => "Hills",
        WorkoutType.RacePace => "Race",
        WorkoutType.CrossTraining => "XT",
        WorkoutType.Strength => "Str",
        _ => type.ToString()
    };

    // --- Edit popover state ---
    private ScheduledWorkout? _editTarget;
    private WorkoutType _editType;
    private decimal _editDistance;

    private void OpenEdit(ScheduledWorkout workout)
    {
        _editTarget = workout;
        _editType = workout.Type;
        _editDistance = workout.TargetDistanceMiles;
    }

    private void CancelEdit() => _editTarget = null;

    private async Task SaveEdit()
    {
        if (_editTarget == null) return;
        _editTarget.Type = _editType;
        _editTarget.TargetDistanceMiles = _editType == WorkoutType.Rest ? 0 : _editDistance;
        await WorkoutRepo.UpdateWorkoutAsync(_editTarget);
        _editTarget = null;
    }
}
