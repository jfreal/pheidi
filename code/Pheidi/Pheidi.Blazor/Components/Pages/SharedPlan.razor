@page "/shared/{PlanId:int}"
@using Microsoft.EntityFrameworkCore
@using Pheidi.Blazor.Data
@using Pheidi.Blazor.Components.Shared
@inject AppDbContext Db
@rendermode InteractiveServer

<PageTitle>Shared Training Plan</PageTitle>

@if (plan == null)
{
    <div class="container mt-5 text-center">
        <h3>Plan not found</h3>
        <p class="text-muted">This shared plan link may have expired or been removed.</p>
    </div>
}
else
{
    <div class="container mt-4" style="max-width: 900px;">
        <div class="text-center mb-4">
            <h2>@plan.RaceGoal.Distance.DisplayName() Training Plan</h2>
            <p class="text-muted">Race Date: @plan.RaceGoal.RaceDate.ToString("MMMM d, yyyy")</p>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-3">
                <div class="card text-center p-3">
                    <div class="fw-bold fs-4">@plan.TotalWeeks</div>
                    <small class="text-muted">Weeks</small>
                </div>
            </div>
            <div class="col-3">
                <div class="card text-center p-3">
                    <div class="fw-bold fs-4">@plan.TotalPlannedMiles.ToString("F0")</div>
                    <small class="text-muted">Total Miles</small>
                </div>
            </div>
            <div class="col-3">
                <div class="card text-center p-3">
                    <div class="fw-bold fs-4">@plan.PeakWeeklyMiles.ToString("F0")</div>
                    <small class="text-muted">Peak Week</small>
                </div>
            </div>
            <div class="col-3">
                <div class="card text-center p-3">
                    <div class="fw-bold fs-4">@plan.LongestRun.ToString("F0")</div>
                    <small class="text-muted">Longest Run</small>
                </div>
            </div>
        </div>

        <table class="table table-sm">
            <thead>
                <tr>
                    <th>Week</th>
                    <th>Phase</th>
                    <th>Total Miles</th>
                    <th>Long Run</th>
                    <th>Workouts</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var week in plan.Weeks)
                {
                    <tr>
                        <td>@week.WeekNumber</td>
                        <td>
                            <span class="badge" style="background-color: @GetPhaseColor(week.Phase)">
                                @week.Phase
                            </span>
                        </td>
                        <td>@week.TotalPlannedDistance.ToString("F1")</td>
                        <td>@week.LongRunDistance.ToString("F1")</td>
                        <td>
                            @foreach (var w in week.Workouts.Where(w => w.Type != WorkoutType.Rest))
                            {
                                <span class="badge me-1" style="background-color: @WorkoutColors.Get(w.Type); color: @WorkoutColors.GetText(w.Type)">
                                    @w.Type
                                </span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <p class="text-center text-muted mt-4">
            <small>Generated by Pheidi — no personal data is shared on this page.</small>
        </p>
    </div>
}

@code {
    [Parameter]
    public int PlanId { get; set; }

    private NewTrainingPlan? plan;

    protected override async Task OnInitializedAsync()
    {
        plan = await Db.TrainingPlans
            .Include(p => p.RaceGoal)
            .Include(p => p.Weeks)
                .ThenInclude(w => w.Workouts)
            .Where(p => p.Id == PlanId)
            .FirstOrDefaultAsync();
    }

    private static string GetPhaseColor(TrainingPhase phase) => phase switch
    {
        TrainingPhase.Base => "#28a745",
        TrainingPhase.Build => "#fd7e14",
        TrainingPhase.Peak => "#dc3545",
        TrainingPhase.Taper => "#6f42c1",
        _ => "#6c757d"
    };
}
