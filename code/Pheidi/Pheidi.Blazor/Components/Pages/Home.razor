@page "/"
@rendermode InteractiveServer

<PageTitle>Pheidi - Marathon Training Plans</PageTitle>

<div class="row mt-4">
    <div class="col-3 px-0">

        <strong><i class="fas fa-running"></i> Generation</strong>

        <div class="bg-white rounded p-1 mt-2">

            <form>
                <div class="mb-3">
                    <label class="form-label">Number of Weeks</label>
                    <input type="number" class="form-control form-control-sm" @bind="trainingPlan.NumberOfWeeks" @bind:event="oninput" />
                    <div class="form-text">The number of weeks in your training plan.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Weeks Of Taper</label>
                    <input type="number" class="form-control form-control-sm" @bind="trainingPlan.WeeksOfTaper" @bind:event="oninput" />
                    <div class="form-text">Weeks after your peak training week before the marathon.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Min Run Distance</label>
                    <input type="number" class="form-control form-control-sm" @bind="trainingPlan.MinRunDistance" @bind:event="oninput" />
                    <div class="form-text">Minimum long run distance.</div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Max Run Distance</label>
                    <input type="number" class="form-control form-control-sm" @bind="trainingPlan.LongRunMaxDistance" @bind:event="oninput" />
                    <div class="form-text">Maximum long run distance.</div>
                </div>

                <button type="button" @onclick="Regenerate" class="btn btn-primary">Generate Weeks</button>
            </form>

        </div>
    </div>

    <div class="col-9">

        <strong><i class="far fa-calendar-alt"></i> Schedule</strong>
        <div class="bg-white rounded mt-2 p-1" id="training-plan">
            <div class="row">
                <div class="col-10">
                    <span class="text-muted">Schedule</span>

                    <table class="table bg-white border activity-table mt-2">
                        <thead>
                            <tr>
                                <td>Activity</td>
                                @foreach (var dayConfig in trainingPlan.DayConfigs)
                                {
                                    <td><ActivitySelect DayConfig="dayConfig" OnChanged="StateHasChanged" /></td>
                                }
                                <td></td>
                            </tr>
                            <tr>
                                <td>Effort</td>
                                @foreach (var dayConfig in trainingPlan.DayConfigs)
                                {
                                    <td><EffortSelect DayConfig="dayConfig" OnChanged="StateHasChanged" /></td>
                                }
                                <td></td>
                            </tr>
                            <tr>
                                <td>Distance</td>
                                @foreach (var dayConfig in trainingPlan.DayConfigs)
                                {
                                    <td><DistanceSelect DayConfig="dayConfig" OnChanged="StateHasChanged" /></td>
                                }
                                <td></td>
                            </tr>
                        </thead>
                        <tr>
                            <th>Week</th>
                            <th>Mon</th>
                            <th>Tue</th>
                            <th>Wed</th>
                            <th>Thu</th>
                            <th>Fri</th>
                            <th>Sat</th>
                            <th>Sun</th>
                            <th></th>
                        </tr>

                        <tbody>
                            @foreach (var week in trainingPlan.Weeks)
                            {
                                <tr>
                                    <td>@week.WeekNumber</td>
                                    @foreach (var dayConfig in trainingPlan.DayConfigs)
                                    {
                                        <td>
                                            <DaySummary DayConfig="dayConfig" Week="week" />
                                        </td>
                                    }
                                    <td></td>
                                </tr>
                            }
                        </tbody>
                    </table>

                </div>
                <div class="col-2">
                    <span class="text-muted">Stats</span>

                    <div class="mt-2">
                        <table class="table table-sm table-borderless">
                            <tr>
                                <td>Runs > 16:</td>
                                <td>@trainingPlan.PlanMetrics.RunsOver16</td>
                            </tr>
                            <tr>
                                <td>Runs > 20:</td>
                                <td>@trainingPlan.PlanMetrics.RunsOver20</td>
                            </tr>
                            <tr>
                                <td>Miles > 16</td>
                                <td>@trainingPlan.PlanMetrics.MilesOver16</td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private TrainingPlan trainingPlan = default!;

    protected override void OnInitialized()
    {
        trainingPlan = new TrainingPlan();
        trainingPlan.Generate();
    }

    private void Regenerate()
    {
        trainingPlan.Generate();
    }
}
