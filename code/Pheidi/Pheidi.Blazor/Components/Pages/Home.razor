@page "/"
@rendermode InteractiveServer
@using Pheidi.Blazor.Services
@inject AuthStateService AuthState
@inject PlanStateService PlanState
@inject NavigationManager Navigation

<PageTitle>Pheidi - Running Training Plans</PageTitle>

@if (AuthState.IsAuthenticated)
{
    <div class="text-center mt-5">
        <div class="spinner-border" role="status"></div>
        <p class="mt-2">Loading your plan...</p>
    </div>
}
else
{
    <div class="text-center mt-5">
        <i class="fas fa-running fa-4x text-primary mb-4"></i>
        <h1>Pheidi</h1>
        <p class="lead text-muted">Smart training plans for runners</p>

        <div class="row justify-content-center mt-4">
            <div class="col-md-8 col-lg-6">
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="card-title mb-3">Get your personalized training plan</h5>
                        <ul class="list-unstyled text-start mb-4">
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i>5K to Marathon plans</li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Adapts to your experience level</li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Smart scheduling around your availability</li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Injury tracking and plan adjustments</li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Race time predictions</li>
                        </ul>
                        <a href="/signin" class="btn btn-primary btn-lg">
                            <i class="fas fa-user me-2"></i>Sign In to Get Started
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender && AuthState.IsAuthenticated)
        {
            if (PlanState.HasActivePlan)
                Navigation.NavigateTo("/calendar");
            else
                Navigation.NavigateTo("/setup");
        }
    }
}
