<h4>How much do you want to run?</h4>
<p class="text-muted">Choose the training volume that fits your lifestyle. This is separate from your experience level.</p>

<div class="row g-3">
    @foreach (var mode in Enum.GetValues<VolumeMode>())
    {
        var m = mode;
        <div class="col-md-6">
            <div class="card h-100 @(Profile.VolumeMode == m ? "border-primary bg-light" : "")"
                 @onclick="() => SelectMode(m)"
                 style="cursor: pointer;">
                <div class="card-body">
                    <h5 class="card-title">
                        @m
                        @if (Profile.VolumeMode == m)
                        {
                            <i class="fas fa-check-circle text-primary ms-1"></i>
                        }
                        @if (m == recommendedMode)
                        {
                            <span class="badge bg-success ms-2">Recommended</span>
                        }
                    </h5>
                    <p class="card-text text-muted">@m.Description()</p>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public UserProfile Profile { get; set; } = default!;

    private VolumeMode recommendedMode;

    protected override void OnInitialized()
    {
        recommendedMode = Profile.ExperienceLevel.RecommendedDefault();
        if (Profile.VolumeMode == default)
            Profile.VolumeMode = recommendedMode;
    }

    private void SelectMode(VolumeMode mode)
    {
        Profile.VolumeMode = mode;
    }
}
