<h4>Which days can you train?</h4>
<p class="text-muted">Select at least 3 days, then pick your long run day.</p>

<div class="d-flex gap-2 flex-wrap mb-2">
    @foreach (var day in allDays)
    {
        var d = day;
        var isSelected = selectedDays.Contains(d);
        <div class="text-center">
            <button class="btn btn-lg @(isSelected ? "btn-primary" : "btn-outline-secondary")"
                    style="min-width: 80px;"
                    @onclick="() => ToggleDay(d)">
                @d.ToString()[..3]
            </button>
            @if (isSelected)
            {
                <div class="form-check d-flex justify-content-center mt-1">
                    <input class="form-check-input" type="radio" name="longRunDay"
                           checked="@(longRunDay == d)"
                           @onchange="() => SetLongRunDay(d)" />
                    <label class="form-check-label ms-1 small">Long</label>
                </div>
            }
        </div>
    }
</div>

@if (selectedDays.Count < 3)
{
    <div class="alert alert-warning mt-2">
        <i class="fas fa-exclamation-triangle"></i> Please select at least 3 training days. Currently selected: @selectedDays.Count
    </div>
}
else if (!HasValidLongRunDay)
{
    <div class="alert alert-warning mt-2">
        <i class="fas fa-exclamation-triangle"></i> Please select a long run day.
    </div>
}
else
{
    <div class="alert alert-info mt-2">
        <i class="fas fa-info-circle"></i> @selectedDays.Count days selected. Long run on <strong>@longRunDay</strong>.
    </div>
}

@code {
    [Parameter, EditorRequired]
    public UserProfile Profile { get; set; } = default!;

    [Parameter]
    public EventCallback OnChanged { get; set; }

    private readonly DayOfWeek[] allDays =
    [
        DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday,
        DayOfWeek.Thursday, DayOfWeek.Friday, DayOfWeek.Saturday, DayOfWeek.Sunday
    ];

    private HashSet<DayOfWeek> selectedDays = [];
    private DayOfWeek? longRunDay;

    public bool HasValidLongRunDay => longRunDay.HasValue && selectedDays.Contains(longRunDay.Value);

    protected override void OnInitialized()
    {
        selectedDays = new HashSet<DayOfWeek>(Profile.AvailableDays);
        longRunDay = Profile.AvailableDays.Length > 0 ? Profile.PreferredLongRunDay : null;
    }

    private async Task ToggleDay(DayOfWeek day)
    {
        if (selectedDays.Contains(day))
        {
            selectedDays.Remove(day);
            if (longRunDay == day)
                longRunDay = null;
        }
        else
        {
            selectedDays.Add(day);
        }

        Profile.AvailableDays = selectedDays.OrderBy(d => d).ToArray();
        if (longRunDay.HasValue)
            Profile.PreferredLongRunDay = longRunDay.Value;

        await OnChanged.InvokeAsync();
    }

    private async Task SetLongRunDay(DayOfWeek day)
    {
        longRunDay = day;
        Profile.PreferredLongRunDay = day;
        await OnChanged.InvokeAsync();
    }
}
