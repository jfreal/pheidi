<h4>Which days can you train?</h4>
<p class="text-muted">Select at least 3 days.</p>

<div class="d-flex gap-2 flex-wrap mb-3">
    @foreach (var day in allDays)
    {
        var d = day;
        var isSelected = selectedDays.Contains(d);
        <button class="btn btn-lg @(isSelected ? "btn-primary" : "btn-outline-secondary")"
                style="min-width: 80px;"
                @onclick="() => ToggleDay(d)">
            @d.ToString()[..3]
        </button>
    }
</div>

@if (selectedDays.Count < 3)
{
    <div class="alert alert-warning">
        <i class="fas fa-exclamation-triangle"></i> Please select at least 3 training days. Currently selected: @selectedDays.Count
    </div>
}
else
{
    <div class="mb-3">
        <label class="form-label fw-bold">Preferred long run day</label>
        <select class="form-select" style="max-width: 200px;" @bind="longRunDay" @bind:after="UpdateLongRunDay">
            @foreach (var day in selectedDays.OrderBy(d => d))
            {
                <option value="@day">@day</option>
            }
        </select>
    </div>

    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i> @selectedDays.Count days selected. Long run on <strong>@Profile.PreferredLongRunDay</strong>.
    </div>
}

@code {
    [Parameter, EditorRequired]
    public UserProfile Profile { get; set; } = default!;

    [Parameter]
    public EventCallback OnChanged { get; set; }

    private readonly DayOfWeek[] allDays =
    [
        DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday,
        DayOfWeek.Thursday, DayOfWeek.Friday, DayOfWeek.Saturday, DayOfWeek.Sunday
    ];

    private HashSet<DayOfWeek> selectedDays = [];
    private DayOfWeek longRunDay;

    protected override void OnInitialized()
    {
        selectedDays = new HashSet<DayOfWeek>(Profile.AvailableDays);
        longRunDay = Profile.PreferredLongRunDay;
    }

    private async Task ToggleDay(DayOfWeek day)
    {
        if (selectedDays.Contains(day))
            selectedDays.Remove(day);
        else
            selectedDays.Add(day);

        Profile.AvailableDays = selectedDays.OrderBy(d => d).ToArray();

        // If current long run day was deselected, pick another
        if (!selectedDays.Contains(longRunDay) && selectedDays.Count > 0)
        {
            longRunDay = selectedDays.OrderBy(d => d).Last();
            Profile.PreferredLongRunDay = longRunDay;
        }

        await OnChanged.InvokeAsync();
    }

    private async Task UpdateLongRunDay()
    {
        Profile.PreferredLongRunDay = longRunDay;
        await OnChanged.InvokeAsync();
    }
}
