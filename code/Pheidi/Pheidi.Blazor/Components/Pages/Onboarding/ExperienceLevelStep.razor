<h4>What's your experience level?</h4>
<p class="text-muted">This helps us tailor your plan's intensity and progression.</p>

<div class="row g-3">
    @foreach (var level in Enum.GetValues<ExperienceLevel>())
    {
        var l = level;
        <div class="col-md-4">
            <div class="card h-100 cursor-pointer @(Profile.ExperienceLevel == l ? "border-primary bg-light" : "")"
                 @onclick="() => Profile.ExperienceLevel = l"
                 style="cursor: pointer;">
                <div class="card-body">
                    <h5 class="card-title">
                        @l
                        @if (Profile.ExperienceLevel == l)
                        {
                            <i class="fas fa-check-circle text-primary ms-1"></i>
                        }
                    </h5>
                    <p class="card-text text-muted">@l.Description()</p>
                    <ul class="list-unstyled small">
                        <li><i class="fas fa-running text-muted"></i> Up to @l.MaxRunDaysPerWeek() run days/week</li>
                        @if (!l.AllowIntervalsFromStart())
                        {
                            <li><i class="fas fa-shield-alt text-muted"></i> Gradual intensity build-up</li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    }
</div>

<div class="mt-4">
    <label class="form-label fw-semibold">Date of Birth <span class="text-muted fw-normal">(optional)</span></label>
    <input type="date" class="form-control" style="max-width: 250px;" @bind="Profile.DateOfBirth" />
    @if (Profile.DateOfBirth.HasValue)
    {
        var ageGroup = AgeGroupExtensions.GetAgeGroup(Profile.DateOfBirth);
        <small class="text-muted d-block mt-1">
            Age bracket: <strong>@ageGroup.DisplayName()</strong> — your plan will include age-appropriate recovery and warm-ups.
        </small>
    }
    else
    {
        <small class="text-muted">Helps us adjust recovery windows and warm-up times.</small>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public UserProfile Profile { get; set; } = default!;
}
