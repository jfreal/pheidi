@page "/setup"
@rendermode InteractiveServer
@implements IDisposable
@using Pheidi.Blazor.Services
@using Pheidi.Common.Engines
@inject PlanStateService PlanState
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Pheidi - Setup Your Plan</PageTitle>

@if (!AuthState.IsAuthenticated)
{
    <div class="text-center mt-5">
        <h4>Sign in to create a plan</h4>
        <p class="text-muted">You need to be signed in to set up a training plan.</p>
        <a href="/signin" class="btn btn-primary"><i class="fas fa-user me-2"></i>Sign In</a>
    </div>
    return;
}

<div class="row justify-content-center mt-4">
    <div class="col-lg-8 col-md-10">
        <h3 class="mb-4"><i class="fas fa-running"></i> Set Up Your Training Plan</h3>

        <!-- Step indicators -->
        <div class="d-flex mb-4">
            @for (int i = 0; i < stepNames.Length; i++)
            {
                var stepIndex = i;
                <div class="flex-fill text-center">
                    <div class="step-indicator @(stepIndex == currentStep ? "active" : stepIndex < currentStep ? "completed" : "")">
                        @if (stepIndex < currentStep)
                        {
                            <i class="fas fa-check"></i>
                        }
                        else
                        {
                            @(stepIndex + 1)
                        }
                    </div>
                    <small class="d-block mt-1 @(stepIndex == currentStep ? "fw-bold" : "text-muted")">@stepNames[stepIndex]</small>
                </div>
            }
        </div>

        <div class="bg-white rounded p-4 shadow-sm">
            @switch (currentStep)
            {
                case 0:
                    <RaceGoalStep RaceGoal="PlanState.RaceGoal" />
                    break;
                case 1:
                    <ExperienceLevelStep Profile="PlanState.UserProfile" />
                    @if (BaseBuildingEngine.ShouldOfferBaseBuilding(PlanState.UserProfile.ExperienceLevel))
                    {
                        <div class="alert alert-info mt-3">
                            <i class="fas fa-seedling me-2"></i>
                            <strong>New to running?</strong> We recommend a 4-week base building phase before your training plan starts.
                            <div class="form-check mt-2">
                                <input class="form-check-input" type="checkbox" id="baseBuilding" @bind="includeBaseBuilding" />
                                <label class="form-check-label" for="baseBuilding">
                                    Include base building phase (4 weeks of easy running to build your foundation)
                                </label>
                            </div>
                        </div>
                    }
                    break;
                case 2:
                    <VolumeModeStep Profile="PlanState.UserProfile" />
                    break;
                case 3:
                    <PacePreferenceStep Profile="PlanState.UserProfile" />
                    break;
                case 4:
                    <AvailableDaysStep Profile="PlanState.UserProfile" OnChanged="StateHasChanged" />
                    break;
                case 5:
                    <PlanGenerationStep RaceGoal="PlanState.RaceGoal" Profile="PlanState.UserProfile" OnGenerate="GeneratePlan" />
                    break;
            }
        </div>

        <div class="d-flex justify-content-between mt-3">
            <button class="btn btn-outline-secondary" @onclick="PreviousStep" disabled="@(currentStep == 0)">
                <i class="fas fa-arrow-left"></i> Back
            </button>

            @if (currentStep < stepNames.Length - 1)
            {
                <button class="btn btn-primary" @onclick="NextStep" disabled="@(!CanAdvance())">
                    Next <i class="fas fa-arrow-right"></i>
                </button>
            }
        </div>
    </div>
</div>

@code {
    private int currentStep = 0;
    private bool includeBaseBuilding;
    private readonly string[] stepNames = ["Race Goal", "Experience", "Volume", "Pace", "Schedule", "Generate"];

    protected override void OnInitialized()
    {
        AuthState.OnAuthStateChanged += HandleAuthStateChanged;
        if (PlanState.RaceGoal.RaceDate == default)
            PlanState.RaceGoal.RaceDate = DateTime.Today.AddMonths(4);
    }

    private Task HandleAuthStateChanged() => InvokeAsync(StateHasChanged);

    private void NextStep()
    {
        if (currentStep < stepNames.Length - 1 && CanAdvance())
            currentStep++;
    }

    private void PreviousStep()
    {
        if (currentStep > 0)
            currentStep--;
    }

    private bool CanAdvance() => currentStep switch
    {
        0 => PlanState.RaceGoal.RaceDate > DateTime.Today,
        1 => true, // Experience
        2 => true, // Volume
        3 => true, // Pace
        4 => PlanState.UserProfile.AvailableDays.Length >= 3
             && PlanState.UserProfile.AvailableDays.Contains(PlanState.UserProfile.PreferredLongRunDay),
        _ => true
    };

    private async Task GeneratePlan()
    {
        var plan = await PlanState.GeneratePlanAsync();

        // Prepend base building weeks if selected
        if (includeBaseBuilding)
        {
            var bbEngine = new BaseBuildingEngine();
            var planStartDate = plan.Weeks.Min(w => w.WeekStartDate);
            var baseWeeks = bbEngine.GenerateBaseBuildingPhase(PlanState.UserProfile, planStartDate);
            plan.Weeks.InsertRange(0, baseWeeks);
        }

        Navigation.NavigateTo("/calendar");
    }

    public void Dispose()
    {
        AuthState.OnAuthStateChanged -= HandleAuthStateChanged;
    }
}
