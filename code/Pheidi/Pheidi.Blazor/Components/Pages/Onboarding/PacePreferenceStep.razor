<h4>How do you want pace guidance?</h4>
<p class="text-muted">Choose how we describe your workout intensity. You can change this anytime.</p>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100 @(Profile.PacePreference == PacePreference.RPE ? "border-primary bg-light" : "")"
             @onclick="() => Profile.PacePreference = PacePreference.RPE"
             style="cursor: pointer;">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="fas fa-heartbeat"></i> Effort-Based (RPE)
                    @if (Profile.PacePreference == PacePreference.RPE)
                    {
                        <i class="fas fa-check-circle text-primary ms-1"></i>
                    }
                </h5>
                <p class="card-text">Workouts described by how they should <strong>feel</strong>.</p>
                <div class="small text-muted">
                    <p class="mb-1">Examples:</p>
                    <ul class="mb-0">
                        <li>"Conversational pace"</li>
                        <li>"Comfortably hard"</li>
                        <li>"Hard, breathing heavy"</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100 @(Profile.PacePreference == PacePreference.VDOT ? "border-primary bg-light" : "")"
             @onclick="() => Profile.PacePreference = PacePreference.VDOT"
             style="cursor: pointer;">
            <div class="card-body">
                <h5 class="card-title">
                    <i class="fas fa-stopwatch"></i> Pace-Based (VDOT)
                    @if (Profile.PacePreference == PacePreference.VDOT)
                    {
                        <i class="fas fa-check-circle text-primary ms-1"></i>
                    }
                </h5>
                <p class="card-text">Workouts described with specific <strong>pace ranges</strong>.</p>
                <div class="small text-muted">
                    <p class="mb-1">Examples:</p>
                    <ul class="mb-0">
                        <li>"8:30 - 9:15 /mile"</li>
                        <li>"7:30 - 7:50 /mile"</li>
                        <li>"6:45 - 7:00 /mile"</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@if (Profile.PacePreference == PacePreference.VDOT)
{
    <div class="mt-3 p-3 bg-light rounded">
        <label class="form-label fw-bold">VDOT Value <span class="text-muted fw-normal">(optional)</span></label>
        <input type="number" class="form-control" style="max-width: 120px"
               min="20" max="85" step="1"
               @bind="Profile.VdotValue" @bind:event="oninput" />
        <div class="form-text">Enter your VDOT if you know it, or we'll estimate from your race history.</div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public UserProfile Profile { get; set; } = default!;
}
