@using Pheidi.Common.Services
@implements IAsyncDisposable
@inject ICalExportService ICalService
@inject PdfExportService PdfService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="d-flex align-items-center gap-2 flex-wrap small">
    <span class="text-muted" style="font-size: 0.8rem;"><i class="fas fa-download me-1"></i>Export:</span>
    <button class="btn btn-sm btn-outline-primary py-0 px-2" @onclick="DownloadIcs" title="Download .ics file">
        <i class="fas fa-calendar-alt me-1"></i>.ics
    </button>
    <button class="btn btn-sm btn-outline-info py-0 px-2" @onclick="DownloadPdf" title="Download PDF">
        <i class="fas fa-file-pdf me-1"></i>PDF
    </button>
    <button class="btn btn-sm btn-outline-secondary py-0 px-2" @onclick="PrintPlan" title="Print">
        <i class="fas fa-print"></i>
    </button>

    <span class="text-muted ms-2" style="font-size: 0.8rem;">Share:</span>
    <div class="input-group input-group-sm" style="width: auto; max-width: 220px;">
        <input type="text" class="form-control form-control-sm py-0" value="@subscribeUrl" readonly style="font-size: 0.75rem;" />
        <button class="btn btn-sm btn-outline-secondary py-0" @onclick="CopySubscribeUrl" title="Copy subscribe URL">
            <i class="fas fa-copy"></i>
        </button>
    </div>
    <div class="input-group input-group-sm" style="width: auto; max-width: 220px;">
        <input type="text" class="form-control form-control-sm py-0" value="@shareUrl" readonly style="font-size: 0.75rem;" />
        <button class="btn btn-sm btn-outline-secondary py-0" @onclick="CopyShareUrl" title="Copy share URL">
            <i class="fas fa-share-alt"></i>
        </button>
    </div>

    @if (showCopied)
    {
        <span class="text-success small"><i class="fas fa-check me-1"></i>Copied!</span>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public NewTrainingPlan Plan { get; set; } = default!;

    [Parameter]
    public string UserShareToken { get; set; } = string.Empty;

    private string subscribeUrl = string.Empty;
    private string shareUrl = string.Empty;
    private bool showCopied;
    private IJSObjectReference? _jsModule;

    protected override void OnInitialized()
    {
        var baseUrl = Navigation.BaseUri.TrimEnd('/');
        subscribeUrl = $"{baseUrl}/api/calendar/{UserShareToken}";
        shareUrl = $"{baseUrl}/api/shared/{Plan.ShareToken}";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/fileDownload.js");
        }
    }

    private async Task DownloadIcs()
    {
        var bytes = ICalService.GenerateIcsFile(Plan);
        var base64 = Convert.ToBase64String(bytes);
        if (_jsModule != null)
            await _jsModule.InvokeVoidAsync("downloadFile", base64, "text/calendar", "training-plan.ics");
    }

    private async Task CopySubscribeUrl()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", subscribeUrl);
        showCopied = true;
        StateHasChanged();
        await Task.Delay(2000);
        showCopied = false;
    }

    private async Task CopyShareUrl()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", shareUrl);
        showCopied = true;
        StateHasChanged();
        await Task.Delay(2000);
        showCopied = false;
    }

    private async Task PrintPlan()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private async Task DownloadPdf()
    {
        var bytes = PdfService.GeneratePdfBytes(Plan);
        var base64 = Convert.ToBase64String(bytes);
        if (_jsModule != null)
            await _jsModule.InvokeVoidAsync("downloadFile", base64, "text/html", "training-plan.html");
    }

    public async ValueTask DisposeAsync()
    {
        if (_jsModule != null)
        {
            await _jsModule.DisposeAsync();
        }
    }
}
