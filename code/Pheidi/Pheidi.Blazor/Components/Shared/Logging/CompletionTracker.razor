@using Pheidi.Common.Services

<div class="card">
    <div class="card-body">
        <h6 class="card-title"><i class="fas fa-chart-line me-1"></i> Progress</h6>

        <div class="progress mb-2" style="height: 20px;">
            <div class="progress-bar @ProgressBarClass()" role="progressbar"
                 style="width: @percentage%;" aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100">
                @percentage.ToString("F0")%
            </div>
        </div>

        <div class="d-flex justify-content-between small text-muted">
            <span>@Plan.CompletedWorkouts completed</span>
            <span>@Plan.TotalRunWorkouts total workouts</span>
        </div>

        <p class="small mt-2 mb-0">
            @WorkoutLoggingService.GetCompletionMessage(percentage, Plan.CompletedWorkouts)
        </p>

        @if (percentage < 90 && Plan.CompletedWorkouts > 0)
        {
            <div class="small text-muted mt-1">
                Target: 90% completion
            </div>
        }
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public NewTrainingPlan Plan { get; set; } = default!;

    private decimal percentage => CalculateWeightedPercentage();

    private decimal CalculateWeightedPercentage()
    {
        var runWorkouts = Plan.Weeks
            .SelectMany(w => w.Workouts)
            .Where(w => w.IsRunWorkout)
            .ToList();

        if (runWorkouts.Count == 0) return 0;

        decimal weightedCompleted = runWorkouts
            .Where(w => w.Status == WorkoutStatus.Completed)
            .Sum(w => (w.CompletionPercent ?? 100) / 100m);

        return Math.Round(weightedCompleted / runWorkouts.Count * 100, 1);
    }

    private string ProgressBarClass() => percentage switch
    {
        >= 90 => "bg-success",
        >= 70 => "bg-primary",
        >= 50 => "bg-warning",
        _ => "bg-secondary"
    };
}
