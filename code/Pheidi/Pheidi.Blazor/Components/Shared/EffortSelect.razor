@if (DayConfig.Activity != Activity.Rest)
{
    <div class="dropdown">
        <button class="btn btn-type dropdown-toggle border" type="button" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="@IconMapping.EffortType[DayConfig.EffortType].Icon"></i>
        </button>
        <div class="dropdown-menu">
            @foreach (var (effortType, mapping) in IconMapping.EffortType)
            {
                <a class="dropdown-item" @onclick="@(() => SelectEffort(effortType))">
                    <i class="@mapping.Icon"></i> @mapping.Name
                </a>
            }
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public DayConfig DayConfig { get; set; } = default!;

    [Parameter]
    public EventCallback OnChanged { get; set; }

    private void SelectEffort(EffortType effortType)
    {
        DayConfig.EffortType = effortType;
        OnChanged.InvokeAsync();
    }
}
